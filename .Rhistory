# Load required libraries
library(dplyr)
library(ggplot2)
library(countrycode)
# Add continent column to covid_final using countrycode
covid_regional <- covid_final %>%
mutate(continent = countrycode(
sourcevar = Country,
origin = "country.name",
destination = "continent",
custom_match = c(
"USA" = "United States",
"UK" = "United Kingdom",
"Czech Republic" = "Czechia",
"Democratic Republic of the Congo" = "Congo, Democratic Republic of the",
"Republic of the Congo" = "Congo, Republic of the"
)
)) %>%
filter(!is.na(continent)) %>%  # Remove unmatched countries
mutate(continent = case_when(
continent == "Americas" ~ "Americas",  # Group Americas together
continent == "Europe" ~ "Europe",      # Group Europe together
TRUE ~ continent                      # Keep other continents as is
))
# Aggregate data for both Percent and Deaths per Million
covid_summary <- covid_regional %>%
group_by(continent) %>%
summarise(
Percent = mean(Percent, na.rm = TRUE),          # Mean vaccination percentage
`Deaths / million` = mean(`Deaths / million`, na.rm = TRUE)  # Mean deaths per million
)
# Ensure only 7 continents (adjust based on your dataset)
continents_7 <- c("Africa", "Americas", "Asia", "Europe", "Oceania", "Antarctica")
covid_summary <- covid_summary %>%
filter(continent %in% continents_7)
# Plot 1: Violin plot for Vaccination Percentage
ggplot(covid_summary, aes(x = continent, y = Percent, fill = continent)) +
geom_violin(alpha = 0.7) +
labs(title = "Vaccination % Distribution by Continent",
x = "Continent", y = "Vaccination Percentage") +
theme_minimal() +
theme(legend.position = "none")
# Plot 2: Boxplot for Deaths per Million
ggplot(covid_summary, aes(x = continent, y = `Deaths / million`, fill = continent)) +
geom_boxplot(outlier.shape = 21, outlier.fill = "red") +
theme_minimal() +
labs(title = "Regional Comparison of COVID-19 Death Rates",
x = "Continent",
y = "Deaths per Million",
caption = "Data from Wikipedia (scraped tables) and and countrycode") +
theme(plot.title = element_text(hjust = 0.5, face = "bold"),
axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "none")  # No legend needed for fill
# Get world map data with continent information
world <- ne_countries(scale = "medium", returnclass = "sf") %>%
select(name, continent) %>%
mutate(name = as.character(name))  # Ensure name is character for merging
# Merge with covid_final to add continent
covid_with_continent <- merge(covid_final, world, by.x = "Country", by.y = "name", all.x = TRUE) %>%
filter(!is.na(continent)) %>%  # Remove countries with missing continent data
mutate(continent = as.factor(continent))  # Ensure continent is a factor
# Boxplot 1: Vaccination Rates by Continent
boxplot_vaccination <- ggplot(covid_with_continent, aes(x = continent, y = Percent, fill = continent)) +
geom_boxplot(alpha = 0.7) +
scale_fill_brewer(palette = "Set2", name = "Continent") +
labs(
title = "COVID-19 Vaccination Rates by Continent",
x = "Continent",
y = "Vaccination Percentage (%)",
caption = "Data Source: Wikipedia (COVID-19 Vaccine Distribution)"
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5, size = 14, face = "bold"),
axis.title = element_text(size = 12),
axis.text.x = element_text(angle = 45, hjust = 1, size = 10),
legend.position = "none",  # Remove legend for clarity
plot.caption = element_text(size = 8, hjust = 0)
)
