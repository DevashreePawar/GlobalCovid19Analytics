mutate(continent = countrycode(
sourcevar = Country,
origin = "country.name",
destination = "continent",
custom_match = c(
"USA" = "United States",
"UK" = "United Kingdom",
"Czech Republic" = "Czechia",
"Democratic Republic of the Congo" = "Congo, Democratic Republic of the",
"Republic of the Congo" = "Congo, Republic of the"
)
)) %>%
filter(!is.na(continent)) %>%  # Remove unmatched countries
mutate(continent = case_when(
continent == "Americas" ~ "Americas",  # Group Americas together
continent == "Europe" ~ "Europe",      # Group Europe together
TRUE ~ continent                      # Keep other continents as is
))
