> # Server
> server <- function(input, output) {
+   
+   # Reactive data for scatter plot filtering
+   filtered_data <- reactive({
+     if (input$continent_scatter == "All") {
+       covid_final
+     } else {
+       covid_final %>% filter(continent == input$continent_scatter)
+     }
+   })
+   
+   # Choropleth Map
+   output$choropleth_map <- renderPlot({
+     world_covid <- world_map %>%
+       left_join(covid_final, by = c("name" = "Country"))
+     
+     ggplot(world_covid) +
+       geom_sf(aes(fill = `Deaths / million`)) +
+       scale_fill_gradient(low = "lightblue", high = "darkred", na.value = "grey90",
+                           name = "Deaths per Million") +
+       theme_minimal() +
+       labs(title = "Global Variation in COVID-19 Death Rates",
+            subtitle = "Deaths per Million by Country",
+            caption = "Data from Local Files") +
+       theme(legend.position = "bottom",
+             plot.title = element_text(hjust = 0.5, face = "bold", size = 16),
+             plot.subtitle = element_text(hjust = 0.5, size = 12))
+   })
+   
+   # Scatter Plot
+   output$scatter_plot <- renderPlot({
+     data_plot <- filtered_data() %>% filter(!is.na(Percent))
+     
+     if (nrow(data_plot) == 0) {
+       ggplot() + 
+         geom_text(aes(x = 0.5, y = 0.5, label = "No data available for selected continent"), 
+                   x = 0.5, y = 0.5, vjust = 0.5, hjust = 0.5, size = 5) +
+         theme_void()
+     } else {
+       ggplot(data_plot, aes(x = Percent, y = `Deaths / million`)) +
+         geom_point(aes(size = Deaths), alpha = 0.5, color = "steelblue", na.rm = TRUE) +
+         geom_smooth(method = "lm", se = TRUE, color = "darkred", linetype = "dashed", size = 1.0, na.rm = TRUE) +
+         scale_size_continuous(name = "Total Deaths", range = c(2, 12)) +
+         theme_minimal() +
+         labs(
+           title = "Vaccination Rates vs. COVID-19 Death Rates",
+           x = "Vaccination Percentage (%)",
+           y = "Deaths per Million",
+           caption = "Data from Local Files"
+         ) +
+         theme(
+           plot.title = element_text(hjust = 0.5, face = "bold", size = 14),
+           axis.title = element_text(size = 12),
+           axis.text = element_text(size = 10),
+           legend.position = "right"
+         )
+     }
+   })
+   
+   # Vaccination Boxplot
+   output$vaccination_boxplot <- renderPlot({
+     ggplot(covid_final, aes(x = continent, y = Percent, fill = continent)) +
+       geom_boxplot(alpha = 0.7, outlier.shape = 21, outlier.fill = "white", na.rm = TRUE) +
+       scale_fill_viridis_d(option = "viridis", name = "Continent") +
+       labs(
+         title = "COVID-19 Vaccination Rates by Continent",
+         x = "Continent",
+         y = "Vaccination Percentage (%)",
+         caption = "Data Source: Local Files"
+       ) +
+       theme_minimal() +
+       theme(
+         plot.title = element_text(hjust = 0.5, size = 14, face = "bold"),
+         axis.title = element_text(size = 12),
+         axis.text.x = element_text(angle = 45, hjust = 1, size = 10),
+         legend.position = "none",
+         plot.caption = element_text(size = 8, hjust = 0)
+       ) +
+       coord_flip()
+   })
+   
+   # Deaths Boxplot
+   output$deaths_boxplot <- renderPlot({
+     ggplot(covid_final, aes(x = continent, y = `Deaths / million`, fill = continent)) +
+       geom_boxplot(alpha = 0.7, outlier.shape = 21, outlier.fill = "white", na.rm = TRUE) +
+       scale_fill_viridis_d(option = "viridis", name = "Continent") +
+       labs(
+         title = "COVID-19 Deaths per Million by Continent",
+         x = "Continent",
+         y = "Deaths per Million",
+         caption = "Data Source: Local Files"
+       ) +
+       theme_minimal() +
+       theme(
+         plot.title = element_text(hjust = 0.5, size = 14, face = "bold"),
+         axis.title = element_text(size = 12),
+         axis.text.x = element_text(angle = 45, hjust = 1, size = 10),
+         legend.position = "none",
+         plot.caption = element_text(size = 8, hjust = 0)
+       ) +
+       coord_flip()
+   })
+   
+   # Histogram
+   output$histogram_plot <- renderPlot({
+     data_hist <- covid_final %>%
+       filter(!is.na(Percent)) %>%
+       mutate(High_Mortality = ifelse(`Deaths / million` > input$mortality_threshold, "High", "Low"))
+     
+     ggplot(data_hist, aes(x = Percent, fill = High_Mortality)) +
+       geom_histogram(position = "identity", alpha = 0.6, bins = 30, color = "white") +
+       scale_fill_manual(values = c("High" = "#D55E00", "Low" = "#0072B2"),
+                         labels = c(sprintf("High (>%d deaths/million)", input$mortality_threshold),
+                                    sprintf("Low (≤%d deaths/million)", input$mortality_threshold))) +
+       labs(
+         title = "Vaccination Rates by Mortality Level",
+         subtitle = "Comparing Countries with High and Low COVID-19 Mortality",
+         x = "Vaccination Rate (%)",
+         y = "Number of Countries",
+         fill = "Mortality Level"
+       ) +
+       theme_minimal(base_size = 14) +
+       theme(
+         plot.title = element_text(face = "bold", hjust = 0.5, size = 16),
+         plot.subtitle = element_text(hjust = 0.5, size = 12),
+         axis.title = element_text(face = "bold", size = 12),
+         legend.position = "right"
+       )
+   })
+ }
